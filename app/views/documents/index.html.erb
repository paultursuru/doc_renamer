<% content_for :title, "Renommeur de documents (local)" %>

<main class="wrap" data-controller="renamer">
  <header class="head">
    <h1>📄 Renommeur de documents</h1>
    <p class="sub">100&nbsp;% local — vos fichiers ne quittent jamais votre machine.</p>
    <div id="status" class="status <%= @online ? 'ok' : 'ko' %>"
         data-controller="lm-status">
      <span class="dot"></span>
      <span class="label" data-lm-status-target="label">
        <% if @online %>
          LM&nbsp;Studio connecté — modèle&nbsp;: <code><%= @model %></code>
        <% else %>
          LM&nbsp;Studio injoignable — démarre le serveur (onglet Developer)
        <% end %>
      </span>
    </div>
  </header>

  <div class="dropzone" tabindex="0"
       data-renamer-target="dropzone"
       data-action="click->renamer#openPicker keydown->renamer#pickerKeydown
                    dragenter->renamer#dragOver dragover->renamer#dragOver
                    dragleave->renamer#dragLeave drop->renamer#drop">
    <input type="file" multiple hidden
           data-renamer-target="fileInput"
           data-action="renamer#inputChanged">
    <div class="dz-inner">
      <div class="dz-icon">⬆️</div>
      <p><strong>Glissez vos fichiers ici</strong></p>
      <p class="muted">ou cliquez pour les sélectionner (PDF, DOCX, TXT, MD…)</p>
    </div>
  </div>

  <div class="progress" data-renamer-target="progress" hidden>
    <div class="bar"><div class="fill" data-renamer-target="progressFill"></div></div>
    <span class="count" data-renamer-target="progressCount"></span>
  </div>

  <div class="list" data-renamer-target="list" hidden></div>

  <div class="actions">
    <button class="btn primary" data-renamer-target="renameBtn"
            data-action="renamer#rename" disabled>✨ Renommer</button>
    <button class="btn" data-renamer-target="downloadAllBtn"
            data-action="renamer#downloadAll" hidden>⬇️ Tout télécharger (zip)</button>
    <button class="btn ghost" data-renamer-target="clearBtn"
            data-action="renamer#clear" hidden>Effacer</button>
  </div>

  <p class="error" data-renamer-target="error" hidden></p>
</main>
